# TruthLayer — environment variables
# Copy to .env and fill in values.

# Postgres URI. If empty, API uses in-memory (dev only).
DATABASE_URL=

# JWT signing secret. Generate: openssl rand -hex 32
TL_JWT_SECRET=

# Port (default 8787)
PORT=8787

# CORS origins (comma-separated). Production example:
# TL_CORS_ORIGINS=https://truthlayer.app,https://x.com,https://twitter.com
TL_CORS_ORIGINS=

# Claim web app: API base URL (build-time for Vite)
TL_API_BASE=http://localhost:8787
