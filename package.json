{
  "name": "truthlayer",
  "private": true,
  "version": "0.0.1",
  "description": "TruthLayer monorepo: Chrome extension + API + shared types.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:extension": "npm run dev --workspace apps/extension",
    "dev:api": "npm run dev --workspace apps/api"
  },
  "engines": {
    "node": ">=20"
  }
}
